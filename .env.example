# ─────────────────────────────────────────────
# AlphaSignal — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Clerk Auth (optional — user accounts disabled when not set)
# 1. Sign up at https://clerk.com and create an application
# 2. Copy keys from: Dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Backend JWKS URL — format: https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# Frontend
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# PostgreSQL (used by Docker Compose and the backend)
POSTGRES_USER=alphasignal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=alphasignal
DATABASE_URL=postgresql+asyncpg://alphasignal:changeme@db:5432/alphasignal

# Stock universe — comma-separated tickers to track
US_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META
# A-share: Moutai (600519), Wuliangye (000858), CATL (300750)
CN_TICKERS=600519,000858,300750

# Ingestion schedule (minutes between RSS fetch runs)
FETCH_INTERVAL_MINUTES=15

# Alert thresholds
# |score| above this triggers alert
ALERT_SENTIMENT_THRESHOLD=0.85
ALERT_CONFIDENCE_THRESHOLD=0.90

# Optional: Webhook URL for alerts (leave blank to disable)
ALERT_WEBHOOK_URL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
